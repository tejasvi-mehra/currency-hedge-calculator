APP_NAME=currency-hedge-calculator
APP_ENV=development
LOG_LEVEL=info
LOG_ENCODING=console

SERVER_LISTEN_ADDR=:8080
SERVER_HEALTH_PATH=/healthz
SERVER_ALLOWED_ORIGINS=*
SERVER_REQUEST_TIMEOUT=8s
SERVER_MAX_BODY_BYTES=1048576
SERVER_MAX_TRANSACTIONS=500
SERVER_RATE_LIMIT_MAX_REQUESTS=120
SERVER_RATE_LIMIT_WINDOW=1m
SERVER_IDEMPOTENCY_TTL=24h

API_AUTH_KEY=dev-api-key

FX_BASE_URL=https://open.er-api.com
FX_HISTORICAL_BASE_URL=https://api.frankfurter.app
FX_TIMEOUT=5s
FX_RETRY_MAX_ATTEMPTS=3
FX_RETRY_INITIAL=200ms
FX_RETRY_MAX=2s
FX_CACHE_TTL=5m
FX_QUOTE_FRESHNESS_SLA=10m
FX_SETTLEMENT_SPREAD_BPS=15
FX_PROVIDER_MARKUP_BPS=10
FX_SUPPORTED_CURRENCIES=USD,EUR,BRL,MXN,COP,ARS,CLP

EXPOSURE_DEFAULT_RISK_THRESHOLD_PERCENTAGE=2
DATA_TEST_DATA_PATH=data/analytics_test_transactions.json
